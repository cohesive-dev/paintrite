# Azure Communication Services — Email
# Copy to .env.local and fill in the real value (.env.local is gitignored).
# On Vercel, set this as an Environment Variable instead.
ACS_CONNECTION_STRING="endpoint=https://<resource>.communication.azure.com/;accesskey=<key>"

# This is the only variable. Hard-coded in lib/notify.ts, not configured here:
#   - sender address (DoNotReply@notification.getcohesiveai.com)
#   - lead recipients (NOTIFY_TO / NOTIFY_BCC)
