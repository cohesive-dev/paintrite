# Azure Communication Services — Email
# Copy to .env.local and fill in real values (.env.local is gitignored).
ACS_CONNECTION_STRING="endpoint=https://<resource>.communication.azure.com/;accesskey=<key>"
ACS_SENDER_ADDRESS="DoNotReply@<verified-domain>"

# Note: lead notification recipients are hard-coded in lib/notify.js
# (NOTIFY_TO / NOTIFY_BCC), not configured here.
